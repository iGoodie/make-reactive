{
  "name": "@igoodie/make-reactive",
  "version": "1.0.0",
  "description": "",
  "repository": "github:iGoodie/make-reactive",
  "license": "CC BY-SA 4.0",
  "author": {
    "name": "iGoodie",
    "url": "https://github.com/iGoodie",
    "email": "igoodie@programmer.net"
  },
  "keywords": [
    "generate",
    "hook",
    "make",
    "reactive",
    "complex",
    "util",
    "monkey",
    "patch",
    "patcher"
  ],
  "main": "./dist/@igoodie/make-reactive.umd.js",
  "module": "./dist/@igoodie/make-reactive.es.js",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "import": "./dist/@igoodie/make-reactive.es.js",
      "require": "./dist/@igoodie/make-reactive.umd.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:demo": "tsc && vite build -c vite.config.demo.ts",
    "preview": "vite preview",
    "lint": "eslint src --ext ts,tsx",
    "lint:fix": "pnpm run lint --fix",
    "type-check": "tsc --project tsconfig.json --pretty --noEmit",
    "ci": "pnpm run lint && pnpm run type-check",
    "predeploy": "cd demo && pnpm i && pnpm build",
    "deploy": "gh-pages -d demo/dist"
  },
  "devDependencies": {
    "@types/node": "^20.8.2",
    "@types/react": "^18.2.19",
    "@types/react-dom": "^18.2.10",
    "@vitejs/plugin-react": "^4.1.0",
    "gh-pages": "^6.3.0",
    "pnpm": "^8.8.0",
    "react-dom": "^18.2.0",
    "sass": "^1.68.0",
    "vite": "^4.4.11",
    "vite-plugin-dts": "^3.6.0",
    "vite-plugin-linter": "^2.0.6",
    "vite-tsconfig-paths": "^4.2.1"
  },
  "peerDependencies": {
    "react": "^18.2.0"
  }
}
